            ],
            "url": {
              "raw": "{{gateway_url}}/api/automation/logs",
              "host": ["{{gateway_url}}"],
              "path": ["api", "automation", "logs"]
            }
          }
        }
      ]
    },
    {
      "name": "Crop Inventory",
      "item": [
        {
          "name": "Create Crop",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Tomato\",\n  \"variety\": \"Cherry\",\n  \"zoneId\": 1\n}"
            },
            "url": {
              "raw": "{{gateway_url}}/api/crops",
              "host": ["{{gateway_url}}"],
              "path": ["api", "crops"]
            }
          }
        },
        {
          "name": "Update Crop Status",
          "request": {
            "method": "PUT",
            "header": [
