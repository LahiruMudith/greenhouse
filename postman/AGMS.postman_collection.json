{
  "info": {
    "_postman_id": "agms-collection-001",
    "name": "AGMS - Automated Greenhouse Management System",
    "description": "API collection for AGMS microservices via the API Gateway",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "gateway_url",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "jwt_token",
      "value": "YOUR_JWT_TOKEN_HERE",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Zone Management",
      "item": [
        {
          "name": "Create Zone",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Zone A\",\n  \"description\": \"Tomato growing zone\",\n  \"minTemp\": 18.0,\n  \"maxTemp\": 28.0\n}"
            },
            "url": {
              "raw": "{{gateway_url}}/api/zones",
              "host": ["{{gateway_url}}"],
              "path": ["api", "zones"]
            }
          }
        },
        {
          "name": "Get Zone by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{gateway_url}}/api/zones/1",
              "host": ["{{gateway_url}}"],
              "path": ["api", "zones", "1"]
            }
          }
        },
        {
          "name": "Get All Zones",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{gateway_url}}/api/zones",
              "host": ["{{gateway_url}}"],
              "path": ["api", "zones"]
            }
          }
        },
        {
          "name": "Update Zone",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Zone A Updated\",\n  \"description\": \"Updated tomato zone\",\n  \"minTemp\": 20.0,\n  \"maxTemp\": 30.0\n}"
            },
            "url": {
              "raw": "{{gateway_url}}/api/zones/1",
              "host": ["{{gateway_url}}"],
              "path": ["api", "zones", "1"]
            }
          }
        },
        {
          "name": "Delete Zone",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{gateway_url}}/api/zones/1",
              "host": ["{{gateway_url}}"],
              "path": ["api", "zones", "1"]
            }
          }
        }
      ]
    },
    {
      "name": "Sensor Telemetry",
      "item": [
        {
          "name": "Get Latest Readings",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
