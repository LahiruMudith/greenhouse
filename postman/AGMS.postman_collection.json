              "raw": "{\n  \"status\": \"VEGETATIVE\"\n}"
            },
            "url": {
              "raw": "{{gateway_url}}/api/crops/1/status",
              "host": ["{{gateway_url}}"],
              "path": ["api", "crops", "1", "status"]
            }
          }
        },
        {
          "name": "Get All Crops",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{gateway_url}}/api/crops",
