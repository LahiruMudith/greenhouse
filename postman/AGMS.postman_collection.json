                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"deviceId\": \"device-001\",\n  \"zoneId\": \"1\",\n  \"temperature\": 32.5,\n  \"humidity\": 65.0,\n  \"timestamp\": 1712000000000\n}"
            },
            "url": {
              "raw": "{{gateway_url}}/api/automation/process",
              "host": ["{{gateway_url}}"],
              "path": ["api", "automation", "process"]
            }
          }
        },
        {
          "name": "Get Automation Logs",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
